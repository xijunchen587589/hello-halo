{
  "name": "halo",
  "version": "2.1.10-rc.24",
  "description": "AI that gets things done",
  "type": "module",
  "main": "./out/main/index.mjs",
  "author": "Halo Team",
  "license": "MIT",
  "scripts": {
    "dev": "npm run bundle:builtin && cross-env HALO_DATA_DIR=~/.halo-dev electron-vite dev",
    "build": "electron-vite build",
    "prebuild": "node scripts/sync-builtin-apps.mjs",
    "bundle:builtin": "node scripts/sync-builtin-apps.mjs",
    "start": "electron-vite preview",
    "postinstall": "node scripts/postinstall.mjs",
    "bump-rc": "node scripts/bump-rc-version.mjs",
    "build:mac": "npm run bump-rc && npm run prepare:all && npm run build && electron-builder --mac",
    "build:win": "npm run bump-rc && node scripts/prepare-binaries.mjs --platform win && npm run build && electron-builder --win",
    "build:win-x64": "npm run bump-rc && node scripts/prepare-binaries.mjs --platform win && npm run build && electron-builder --win --x64",
    "prepare": "node scripts/prepare-binaries.mjs",
    "prepare:all": "node scripts/prepare-binaries.mjs --platform all",
    "build:mac-x64": "npm run bump-rc && node scripts/prepare-binaries.mjs --platform mac-x64 && npm run build && electron-builder --mac --x64",
    "build:linux": "npm run bump-rc && node scripts/prepare-binaries.mjs --platform linux && npm run build && electron-builder --linux",
    "icons": "bash scripts/generate-icons.sh",
    "release": "npm run prepare:all && npm run build && electron-builder --mac --win --publish always",
    "release:mac": "npm run prepare:all && npm run build && electron-builder --mac --publish always",
    "release:win": "node scripts/prepare-binaries.mjs --platform win && npm run build && electron-builder --win --publish always",
    "release:linux": "node scripts/prepare-binaries.mjs --platform linux && npm run build && electron-builder --linux --publish always",
    "test": "npm run test:check && npm run test:unit",
    "test:check": "node tests/check/binaries.mjs",
    "test:check:mac-arm64": "node tests/check/binaries.mjs --platform mac-arm64",
    "test:check:mac-x64": "node tests/check/binaries.mjs --platform mac-x64",
    "test:check:win": "node tests/check/binaries.mjs --platform win",
    "test:check:linux": "node tests/check/binaries.mjs --platform linux",
    "test:unit": "vitest run --config tests/vitest.config.ts",
    "test:unit:watch": "vitest --config tests/vitest.config.ts",
    "test:e2e": "playwright test --config tests/playwright.config.ts",
    "test:e2e:smoke": "playwright test --config tests/playwright.config.ts --project=smoke",
    "test:e2e:codex-mcp": "playwright test --config tests/playwright.config.ts --project=codex-mcp",
    "i18n:extract": "i18next",
    "i18n:translate": "node scripts/translate-i18n.mjs",
    "i18n": "npm run i18n:extract && npm run i18n:translate",
    "build:mobile": "vite build --config vite.config.mobile.ts",
    "cap:sync": "npm run build:mobile && npx cap sync",
    "cap:run:android": "npm run cap:sync && npx cap run android",
    "cap:open:android": "npx cap open android",
    "build:android:debug": "npm run cap:sync && ANDROID_HOME=$HOME/Library/Android/sdk ./android/gradlew -p android assembleDebug",
    "release:android": "npm run cap:sync && ANDROID_HOME=$HOME/Library/Android/sdk ./android/gradlew -p android assembleRelease && node -e \"const v=require('./package.json').version; const fs=require('fs'); fs.mkdirSync('dist',{recursive:true}); fs.copyFileSync('android/app/build/outputs/apk/release/app-release.apk','dist/Halo-'+v+'.apk'); console.log('Output: dist/Halo-'+v+'.apk')\"",
    "cap:open:ios": "npx cap open ios",
    "cap:run:ios": "npm run cap:sync && npx cap run ios"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.89",
    "@anthropic-ai/claude-code": "2.1.89",
    "@anthropic-ai/sdk": "latest",
    "@anthropic-ai/tokenizer": "^0.0.4",
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/ios": "^8.3.0",
    "@capacitor/keyboard": "^8.0.1",
    "@capacitor/local-notifications": "^8.0.2",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@codemirror/commands": "^6.10.1",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-vue": "^0.1.3",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/language": "^6.12.1",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.39.11",
    "@electron-toolkit/preload": "^3.0.0",
    "@electron-toolkit/utils": "^3.0.0",
    "@lezer/highlight": "^1.2.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@openai/codex": "0.128.0",
    "@openai/codex-sdk": "0.128.0",
    "@parcel/watcher": "^2.5.6",
    "@replit/codemirror-lang-svelte": "^6.0.0",
    "@streamdown/code": "^1.0.2",
    "@tailwindcss/typography": "^0.5.19",
    "@types/diff": "^7.0.2",
    "@wecom/aibot-node-sdk": "^1.0.6",
    "better-sqlite3": "^12.6.2",
    "boring-avatars": "^2.0.4",
    "cloudflared": "^0.7.1",
    "clsx": "^2.1.0",
    "croner": "^10.0.1",
    "cronstrue": "^3.14.0",
    "diff": "^8.0.2",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.6.2",
    "express": "^5.1.0",
    "fflate": "^0.8.2",
    "fix-path": "^5.0.0",
    "gpt-tokenizer": "^3.4.0",
    "highlight.js": "^11.11.1",
    "html5-qrcode": "^2.3.8",
    "i18next": "^25.7.4",
    "ignore": "^7.0.5",
    "imapflow": "^1.3.1",
    "jsonrepair": "^3.13.3",
    "katex": "^0.16.47",
    "lucide-react": "^0.555.0",
    "mailparser": "^3.9.8",
    "node-pty": "^1.1.0",
    "nodemailer": "^8.0.1",
    "open": "^10.2.0",
    "pinyin-pro": "^3.28.1",
    "proxy-agent": "^7.0.0",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-arborist": "^3.4.3",
    "react-diff-viewer-continued": "^3.4.0",
    "react-dom": "^18.2.0",
    "react-i18next": "^16.5.2",
    "react-markdown": "^10.1.0",
    "react-virtuoso": "^4.18.1",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "sm-crypto": "^0.4.0",
    "streamdown": "^2.2.0",
    "tailwind-merge": "^2.2.0",
    "uuid": "^13.0.0",
    "ws": "^8.18.3",
    "yaml": "^2.8.2",
    "zod": "^3.24.1",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@playwright/test": "^1.57.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.5",
    "@types/node": "^20.10.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^11.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "cross-env": "^10.1.0",
    "dotenv": "^17.2.4",
    "electron": "~29.4.6",
    "electron-builder": "24.13.1",
    "electron-vite": "^2.0.0",
    "i18next-parser": "^9.3.0",
    "patch-package": "^8.0.1",
    "playwright": "^1.57.0",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.6.1"
  },
  "optionalDependencies": {
    "@hello-halo/agent-sdk": "file:src/sdk/halo-sdk",
    "@parcel/watcher-darwin-arm64": "^2.5.6",
    "@parcel/watcher-darwin-x64": "^2.5.6",
    "@parcel/watcher-linux-x64-glibc": "^2.5.6",
    "@parcel/watcher-win32-x64": "^2.5.6"
  },
  "build": {
    "appId": "com.halo.app",
    "productName": "Halo",
    "npmRebuild": false,
    "beforePack": "./scripts/beforePack.cjs",
    "afterPack": "./scripts/afterPack.cjs",
    "directories": {
      "buildResources": "resources"
    },
    "files": [
      "out/**/*",
      "resources/**/*",
      "product.json",
      "halo-webank/build/dist/**/*",
      "!node_modules/better-sqlite3/prebuilds"
    ],
    "asarUnpack": [
      "node_modules/@openai/codex/bin/**/*",
      "node_modules/@openai/codex/vendor/**/*",
      "node_modules/@openai/codex-*/vendor/**/*",
      "node_modules/@openai/codex-sdk/dist/**/*",
      "node_modules/cloudflared/**/*",
      "node_modules/@parcel/watcher-*/**/*",
      "node_modules/better-sqlite3/build/Release/*.node",
      "node_modules/node-pty/prebuilds/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "openkursar",
      "repo": "hello-halo",
      "releaseType": "release"
    },
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "resources/icon.icns",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "notarize": false,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ]
    },
    "dmg": {
      "window": {
        "width": 540,
        "height": 380
      },
      "contents": [
        {
          "x": 130,
          "y": 180
        },
        {
          "x": 410,
          "y": 180,
          "type": "link",
          "path": "/Applications"
        },
        {
          "x": 270,
          "y": 120,
          "type": "file",
          "path": "resources/README.txt"
        }
      ]
    },
    "win": {
      "icon": "resources/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": false,
      "include": "resources/installer.nsh"
    },
    "linux": {
      "icon": "resources/linux",
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
